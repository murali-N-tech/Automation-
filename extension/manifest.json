{
  "manifest_version": 3,
  "name": "Hire-Me AI: Smart Apply",
  "version": "1.0.0",
  "description": "Autofills job applications using your AI-analyzed resume.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://*.workday.com/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.greenhouse.io/*", "*://*.lever.co/*"],
      "js": ["content.js"]
    }
  ]
}
