{
  "manifest_version": 3,
  "name": "Hire-Me AI: Smart Apply",
  "version": "1.0.0",
  "description": "Autofills job applications using your AI-analyzed resume.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ]
}